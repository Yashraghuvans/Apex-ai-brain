/**
 * {{ClassName}}
 * 
 * FSD Selector Layer Component
 * Responsibility: ALL SOQL queries live exclusively here
 * 
 * Architecture Notes:
 * - Selector is the ONLY place where SOQL queries should exist
 * - Always enforce WITH SECURITY_ENFORCED to prevent data leakage
 * - All query methods return List<SObject> or empty list, never null
 * - Never accepts raw strings for dynamic SOQL (injection prevention)
 * - Query methods are named descriptively: selectById, selectByField, selectWithRelated
 * - Static methods preferred for reusability
 * 
 * @author Generated by sfai
 * @date {{CreatedDate}}
 */
public class {{ClassName}} {

    /**
     * Custom Exception for query failures
     */
    public class {{ClassName}}Exception extends Exception {}

    /**
     * Private constructor - utility class only
     */
    private {{ClassName}}() {}

    /**
     * Query records by ID with security enforcement
     * 
     * @param recordIds Set of record IDs to retrieve
     * @return List of records matching IDs, empty list if none found
     * @throws {{ClassName}}Exception if query fails
     */
    public static List<SObject> selectById(Set<Id> recordIds) {
        if (recordIds == null || recordIds.isEmpty()) {
            return new List<SObject>();
        }

        try {
            return [
                SELECT Id, Name
                FROM {{SObjectType}}
                WHERE Id IN :recordIds
                WITH SECURITY_ENFORCED
                ORDER BY Name ASC
            ];
        } catch (QueryException e) {
            throw new {{ClassName}}Exception('Query failed: ' + e.getMessage(), e);
        } catch (AccessDeniedException e) {
            throw new {{ClassName}}Exception('Insufficient access to query records: ' + e.getMessage(), e);
        }
    }

    /**
     * Query records by a specific field value
     * 
     * @param fieldName The field to query on (must be indexed or use SOQL for loop)
     * @param fieldValue The value to match
     * @return List of matching records, empty list if none found
     * @throws {{ClassName}}Exception if query fails
     */
    public static List<SObject> selectByField(String fieldName, String fieldValue) {
        if (String.isBlank(fieldName) || String.isBlank(fieldValue)) {
            return new List<SObject>();
        }

        try {
            // Use bind variable to prevent SOQL injection
            String query = 'SELECT Id, Name FROM {{SObjectType}} WHERE ' + 
                          String.escapeSingleQuotes(fieldName) + ' = :fieldValue ' +
                          'WITH SECURITY_ENFORCED LIMIT 10000';
            
            // Note: In production, consider using static queries for better performance
            return Database.query(query, AccessLevel.USER_MODE);
        } catch (QueryException e) {
            throw new {{ClassName}}Exception('Query failed: ' + e.getMessage(), e);
        } catch (AccessDeniedException e) {
            throw new {{ClassName}}Exception('Insufficient access: ' + e.getMessage(), e);
        }
    }

    /**
     * Query records with related object data
     * Demonstrates parent relationship queries
     * 
     * @param recordIds Set of IDs for parent records
     * @return List of records with related data populated
     * @throws {{ClassName}}Exception if query fails
     */
    public static List<SObject> selectWithRelated(Set<Id> recordIds) {
        if (recordIds == null || recordIds.isEmpty()) {
            return new List<SObject>();
        }

        try {
            return [
                SELECT Id, Name,
                       Parent__r.Id, Parent__r.Name,
                       (SELECT Id, Value FROM RelatedList__r LIMIT 100)
                FROM {{SObjectType}}
                WHERE Id IN :recordIds
                WITH SECURITY_ENFORCED
                ORDER BY Name ASC
            ];
        } catch (QueryException e) {
            throw new {{ClassName}}Exception('Query failed: ' + e.getMessage(), e);
        } catch (AccessDeniedException e) {
            throw new {{ClassName}}Exception('Insufficient access: ' + e.getMessage(), e);
        }
    }

    /**
     * Aggregate query - count records matching criteria
     * 
     * @param criteria Map of field:value pairs for WHERE clause
     * @return Count of matching records
     */
    public static Integer countRecords(Map<String, Object> criteria) {
        if (criteria == null || criteria.isEmpty()) {
            return 0;
        }

        try {
            AggregateResult result = [
                SELECT COUNT() cnt
                FROM {{SObjectType}}
                WITH SECURITY_ENFORCED
            ];
            return (Integer) result.get('cnt');
        } catch (Exception e) {
            return 0;
        }
    }

    /**
     * Complex SOQL with SOQL for loop for large datasets
     * Safe for querying up to 50,000 records
     * 
     * @return Database.QueryLocator for batch processing
     */
    public static Database.QueryLocator selectForBatch() {
        return Database.getQueryLocator([
            SELECT Id, Name
            FROM {{SObjectType}}
            WHERE CreatedDate = LAST_N_DAYS:30
            WITH SECURITY_ENFORCED
            ORDER BY CreatedDate DESC
        ]);
    }
}
